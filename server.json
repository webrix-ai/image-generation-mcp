{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.shalevshalit/image-generation-mcp",
  "description": "MCP server for AI-powered image generation using Google Gemini models.",
  "status": "active",
  "repository": {
    "url": "https://github.com/mcp-s-ai/image-generation-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registry_type": "npm",
      "registry_base_url": "https://registry.npmjs.org",
      "identifier": "image-generation-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "description": "Your Google Gemini API key for image generation services",
          "is_required": true,
          "format": "string",
          "is_secret": true,
          "name": "GEMINI_API_KEY"
        }
      ]
    }
  ]
}
